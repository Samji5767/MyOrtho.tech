# =============================================================================
# MyOrtho.tech — environment template
# Copy to `.env` and fill in real values. NEVER commit the populated .env file.
# `docker-compose.yml` and the Makefile read these values.
# =============================================================================

# ---------- Database (PostgreSQL) ----------
# Postgres is NOT published to the host; it is only reachable on the internal
# Docker network at host "database". No host port is exposed for security.
POSTGRES_USER=myortho_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=myortho_tech
DATABASE_URL=postgresql://myortho_admin:change_me_in_production@database:5432/myortho_tech
# Max pool connections per backend process (default 20 — reduce on low-memory VPS)
PG_POOL_MAX=20

# ---------- Cache (Redis) ----------
# Redis is NOT published to the host; only reachable on the internal network.
REDIS_URL=redis://redis:6379

# ---------- Backend (NestJS) ----------
BACKEND_PORT=4000
NODE_ENV=development
# Allowed CORS origin for the API. In production set to your frontend domain.
# Multiple origins are not supported via this variable — edit main.ts for multi-origin.
FRONTEND_URL=https://myortho.tech

# ---------- AI Engine (FastAPI) ----------
AI_ENGINE_PORT=8000
# Defaults to CPU for VPS deployment. Set to "cuda" only on a GPU host (and add
# a GPU device reservation back to docker-compose.yml).
AI_DEVICE=cpu

# ---------- Frontend (Next.js) ----------
# Host port for the web app (container still listens on 3000 internally).
FRONTEND_PORT=3005
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AI_URL=http://localhost:8000

# ---------- Supabase (auth / storage) ----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace_with_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# ---------- Observability (OpenTelemetry) ----------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=myortho-backend

# ---------- Security ----------
# Generate strong secrets, e.g.: openssl rand -hex 32
JWT_SECRET=change_me_generate_a_strong_secret
ENCRYPTION_KEY=change_me_32_byte_key_for_phi_at_rest

# ---------- VPS-native authentication (Phase 8) ----------
# Bootstrap admin credentials — set ONCE before first deploy, never commit real values.
# The backend reads these on startup and creates the admin user if it does not exist.
# After first startup the account persists in the DB; these vars can then be removed.
MYORTHO_ADMIN_EMAIL=
MYORTHO_ADMIN_PASSWORD=
MYORTHO_ADMIN_NAME=

# ---------- Stripe (SaaS billing) ----------
# Get keys from https://dashboard.stripe.com/apikeys
# Leave blank to run in mock/free mode (billing endpoints still work, no charges).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products + prices in Stripe dashboard, then paste the price IDs here.
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# ---------- AI / ML pipeline ----------
# URL of the FastAPI AI engine service (internal Docker network by default).
# Set to a real endpoint to enable AI-powered segmentation and treatment planning.
AI_ENGINE_URL=http://ai-engine:8000

# CORS origin for WebSocket connections from the frontend.
# Set to your production frontend domain (e.g. https://myortho.tech).
CORS_ORIGIN=http://localhost:3000

# Shared secret for internal backend ↔ AI engine calls (X-Internal-Token header).
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# Path to trained segmentation model weights inside the AI engine container.
# Leave blank to run in no-inference mode (segmentation jobs will fail with a
# clear error rather than returning random outputs).
MODEL_CHECKPOINT=

# Set to "true" to enable a rule-based scaffold fallback when MODEL_CHECKPOINT is
# absent. Scaffold output is marked with ai_version=0.0.0-rule-based-scaffold and
# clinician_review_required=true. Never enable this in production.
SEGMENTATION_FALLBACK_ENABLED=false

# URL of a real biomechanical treatment-plan AI service.
# Leave blank — and TREATMENT_PLAN_STAGE_FALLBACK_ENABLED unset — to disable
# automated stage generation entirely (recommended for production until real AI
# is integrated). Attempting to generate stages without this will return HTTP 503.
TREATMENT_PLAN_AI_URL=

# Set to "true" to enable a deterministic pseudo-random stage scaffold when
# TREATMENT_PLAN_AI_URL is not set. All generated stages are flagged _is_simulated=true
# and are blocked from doctor approval and export. Never enable in production.
TREATMENT_PLAN_STAGE_FALLBACK_ENABLED=false

# ---------- Copilot / RAG (AI orthodontic assistant) ----------
# LLM provider for the copilot (e.g. "anthropic", "openai"). Leave blank to
# disable the RAG knowledge-base query endpoint.
COPILOT_LLM_PROVIDER=
COPILOT_LLM_API_KEY=
# Embedding API key used to index knowledge chunks (required for query_knowledge_base).
COPILOT_EMBED_API_KEY=
